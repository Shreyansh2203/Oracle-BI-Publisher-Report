ORACLE_USERNAME=your_username@example.com
ORACLE_PASSWORD=your_password
ORACLE_BASE_URL=https://your-instance.fa.ocs.oraclecloud.com
REPORTS_FILE=reports.txt

MAX_BATCH_SIZE=20
REQUEST_TIMEOUT=120
HTTP_POOL_SIZE=10
CACHE_TTL=300
DEBUG=false

# GitHub auto-save — leave empty to disable
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_REPORTS_DIR=reports

# File-age check: serve existing GitHub file if younger than this (hours)
FILE_AGE_THRESHOLD_HOURS=0.6

# CORS — comma-separated origins, or "*" for any. Empty disables cross-origin access.
# Never use "*" in production. Set your frontend origin(s) instead.
# Example: CORS_ORIGINS=https://reports.example.com,https://admin.example.com
CORS_ORIGINS=
